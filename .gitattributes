# .gitattributes — line-ending normalisation.
#
# On Windows, Git's default `core.autocrlf` checks text files out with CRLF. Files that are
# exec-loaded or parsed line-by-line — shell scripts, and the PowerShell build scripts that also
# run on the Linux/macOS CI runners under pwsh — break on a stray CR, so their EOL is pinned to LF
# on every platform. `text=auto` lets Git auto-detect text vs binary for everything else.

# ── Default ──────────────────────────────────────────────────────────────────
* text=auto

# ── LF-mandatory ─────────────────────────────────────────────────────────────
# Cross-platform scripts (the build/*.ps1 helpers run under pwsh on every OS in CI).
*.ps1    text eol=lf
*.sh     text eol=lf
*.bash   text eol=lf

# ── CRLF-mandatory ───────────────────────────────────────────────────────────
*.bat    text eol=crlf
*.cmd    text eol=crlf

# ── Binary (no normalisation) ────────────────────────────────────────────────
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.zip    binary
*.tar    binary
*.tar.gz binary
*.tgz    binary
*.gz     binary
*.nupkg  binary
*.snupkg binary
*.dll    binary
*.exe    binary
*.pdb    binary
*.snk    binary
*.pfx    binary
